# --- Core ---
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000

# --- Database (Postgres + PostGIS) ---
# Local: docker compose up -d   |   Hosted: Supabase connection string
DATABASE_URL=postgresql://rideshare:rideshare@localhost:5432/rideshare

# --- Redis (live locations, rate limits, pub/sub, queues) ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too
JWT_ACCESS_TTL=900          # seconds (15 min)
JWT_REFRESH_TTL=2592000     # seconds (30 days)
OTP_TTL=300                 # seconds
OTP_MAX_REQUESTS_PER_HOUR=3 # per phone — OTP is the true per-signup cost, keep tight
OTP_DEV_MODE=true           # true = log OTP instead of sending SMS (local/dev)

# --- OTP delivery (pluggable adapter) ---
# dev       = log the code only, and return it in the API response (local/E2E)
# veevotech = Pakistani SMS gateway (needs SMS_API_KEY)
# twilio    = SMS or WhatsApp (needs the TWILIO_* values)
# Once this is anything but "dev", the code is NEVER returned by the API,
# even if OTP_DEV_MODE is left true. Set OTP_DEV_MODE=false in production.
SMS_PROVIDER=dev

# VeevoTech
SMS_API_KEY=                # account hash from the VeevoTech dashboard
SMS_SENDER_ID=RideshrPK     # PTA-approved sender mask

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=                # e.g. +14155551234 (WhatsApp-enabled if using whatsapp)
TWILIO_CHANNEL=sms          # sms | whatsapp

# --- Maps provider adapter ---
MAPS_PROVIDER=osm           # osm | google
GOOGLE_MAPS_API_KEY=

# --- Push notifications ---
FCM_SERVICE_ACCOUNT_JSON=   # path or inline JSON for Firebase Cloud Messaging

# --- Object storage (CNIC / license / vehicle docs) ---
STORAGE_PROVIDER=supabase   # supabase | s3
STORAGE_BUCKET=verification-docs
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- Feature flags / marketplace config (config over code) ---
CITY_DEFAULT=lahore
FEATURE_BOOKING_ACCEPT_DECLINE=false   # Phase 2: driver accept/decline
FEATURE_PAYMENTS=false                 # Phase 2
FEATURE_LADIES_ONLY=true
REQUIRE_DRIVER_VERIFICATION_TO_POST=true
BOOKING_FEE_PKR=0                      # Phase 2 monetisation lever

# --- Observability ---
SENTRY_DSN=
LOG_LEVEL=info
